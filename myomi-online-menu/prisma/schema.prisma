generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Dish {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Int
  imageUrl    String?
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  categoryId  String
}

model Category {
  id     String @id // "special-rolls"
  name   String // "Special Rolls"
  imgUrl String
  dishes Dish[]
}

